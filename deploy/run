#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR=${ROOT_DIR:-/home/linuxuser/Web}
FRONTEND_DIR="$ROOT_DIR/frontend"
BACKEND_DIR="$ROOT_DIR/backend"
SITE_DIR=${SITE_DIR:-/var/www/philosophy}
BACKEND_PORT=${BACKEND_PORT:-8080}
BACKEND_PID_FILE=${BACKEND_PID_FILE:-$BACKEND_DIR/backend.pid}
BACKEND_LOG=${BACKEND_LOG:-$BACKEND_DIR/backend-run-live.log}
HEALTH_URL=${HEALTH_URL:-http://127.0.0.1:${BACKEND_PORT}/api/health}
HEALTH_MAX_ATTEMPTS=${HEALTH_MAX_ATTEMPTS:-60}
HEALTH_SLEEP_SECONDS=${HEALTH_SLEEP_SECONDS:-2}

DB_NAME=${DB_NAME:-philosophy_db}
MYSQL_ROOT_USER=${MYSQL_ROOT_USER:-root}
MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD:-Mmoonj10y?}
APP_DB_USER=${APP_DB_USER:-philosophy_user}
APP_DB_PASSWORD=${APP_DB_PASSWORD:-Mmoonj10y?}
SPRING_DATASOURCE_URL_VALUE=${SPRING_DATASOURCE_URL_VALUE:-jdbc:mysql://localhost:3306/${DB_NAME}}
SPRING_DATASOURCE_USERNAME_VALUE=${SPRING_DATASOURCE_USERNAME_VALUE:-$APP_DB_USER}
SPRING_DATASOURCE_PASSWORD_VALUE=${SPRING_DATASOURCE_PASSWORD_VALUE:-$APP_DB_PASSWORD}
APP_FRONTEND_URL=${APP_FRONTEND_URL:-http://localhost:5173}

on_error() {
  local exit_code="$1"
  local line_no="$2"
  echo "Deployment failed at line ${line_no} (exit=${exit_code})" >&2
  if [ -f "$BACKEND_LOG" ]; then
    echo "Last backend log lines:" >&2
    tail -n 120 "$BACKEND_LOG" >&2 || true
  fi
  exit "$exit_code"
}
trap 'on_error $? $LINENO' ERR

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Required command not found: $cmd" >&2
    exit 1
  fi
}

mysql_root_exec() {
  mysql -u"$MYSQL_ROOT_USER" -p"$MYSQL_ROOT_PASSWORD" "$@"
}

show_backend_log_tail() {
  if [ -f "$BACKEND_LOG" ]; then
    tail -n 120 "$BACKEND_LOG" >&2 || true
  fi
}

wait_for_port_release() {
  local port="$1"
  local attempt
  for attempt in $(seq 1 15); do
    if command -v lsof >/dev/null 2>&1; then
      if ! lsof -ti tcp:"$port" >/dev/null 2>&1; then
        return 0
      fi
    elif command -v ss >/dev/null 2>&1; then
      if ! ss -ltn | grep -q ":$port[[:space:]]"; then
        return 0
      fi
    else
      return 0
    fi
    sleep 1
  done
  return 1
}

wait_for_http_health() {
  local attempt
  for attempt in $(seq 1 "$HEALTH_MAX_ATTEMPTS"); do
    if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
      echo "Backend process exited early. Last log lines:" >&2
      show_backend_log_tail
      return 1
    fi

    if command -v curl >/dev/null 2>&1; then
      if curl -fsS "$HEALTH_URL" >/dev/null 2>&1; then
        return 0
      fi
    elif command -v wget >/dev/null 2>&1; then
      if wget -qO- "$HEALTH_URL" >/dev/null 2>&1; then
        return 0
      fi
    elif command -v ss >/dev/null 2>&1; then
      if ss -ltn | grep -q ":${BACKEND_PORT}[[:space:]]"; then
        return 0
      fi
    fi

    sleep "$HEALTH_SLEEP_SECONDS"
  done

  echo "Backend did not become healthy in time after $((HEALTH_MAX_ATTEMPTS * HEALTH_SLEEP_SECONDS)) seconds." >&2
  show_backend_log_tail
  return 1
}

prepare_frontend() {
  echo "[2] build frontend"
  cd "$FRONTEND_DIR"

  if [ -f package-lock.json ]; then
    npm ci
  else
    npm install
  fi

  npm run build
  sudo mkdir -p "$SITE_DIR"
  sudo rm -rf "$SITE_DIR"/*
  sudo cp -r dist/. "$SITE_DIR/"
}

prepare_database_user() {
  echo "[3] update database user"
  require_cmd mysql
  mysql_root_exec <<SQL
CREATE USER IF NOT EXISTS '${APP_DB_USER}'@'localhost' IDENTIFIED BY '${APP_DB_PASSWORD}';
ALTER USER '${APP_DB_USER}'@'localhost' IDENTIFIED BY '${APP_DB_PASSWORD}';
CREATE USER IF NOT EXISTS '${APP_DB_USER}'@'%' IDENTIFIED BY '${APP_DB_PASSWORD}';
ALTER USER '${APP_DB_USER}'@'%' IDENTIFIED BY '${APP_DB_PASSWORD}';
GRANT ALL PRIVILEGES ON ${DB_NAME}.* TO '${APP_DB_USER}'@'localhost';
GRANT ALL PRIVILEGES ON ${DB_NAME}.* TO '${APP_DB_USER}'@'%';
FLUSH PRIVILEGES;
SQL
}

build_backend() {
  echo "[4] build backend"
  cd "$BACKEND_DIR"
  chmod +x ./mvnw
  ./mvnw -q -DskipTests package
}

start_backend() {
  echo "[5] restart backend"
  stop_backend

  BACKEND_JAR=$(find target -maxdepth 1 -type f -name '*.jar' ! -name '*.original' | sort | tail -n 1)
  if [ -z "${BACKEND_JAR:-}" ]; then
    echo "Backend jar not found after build" >&2
    exit 1
  fi

  if [ -f "$BACKEND_LOG" ]; then
    mv "$BACKEND_LOG" "$BACKEND_LOG.$(date +%Y%m%d-%H%M%S).bak"
  fi

  env \
    APP_FRONTEND_URL="$APP_FRONTEND_URL" \
    SPRING_DATASOURCE_URL="$SPRING_DATASOURCE_URL_VALUE" \
    SPRING_DATASOURCE_USERNAME="$SPRING_DATASOURCE_USERNAME_VALUE" \
    SPRING_DATASOURCE_PASSWORD="$SPRING_DATASOURCE_PASSWORD_VALUE" \
    SPRING_SQL_INIT_MODE=always \
    SPRING_SQL_INIT_SCHEMA_LOCATIONS=classpath:schema-mysql.sql \
    nohup java -jar "$BACKEND_JAR" > "$BACKEND_LOG" 2>&1 &
  BACKEND_PID=$!
  echo "$BACKEND_PID" > "$BACKEND_PID_FILE"
}

verify_deployment() {
  echo "[6] wait and verify"
  wait_for_http_health

  if command -v ss >/dev/null 2>&1; then
    ss -ltnp | grep ":${BACKEND_PORT}" || true
  fi

  if command -v mysql >/dev/null 2>&1; then
    mysql_root_exec -D "$DB_NAME" -e "SELECT COUNT(*) AS history_country_count FROM history_country; SELECT COUNT(*) AS history_event_count FROM history_event;" || true
  fi

  if command -v curl >/dev/null 2>&1; then
    curl -fsS "$HEALTH_URL" || true
    curl -fsS "http://127.0.0.1:${BACKEND_PORT}/api/history/snapshot?year=1900" || true
    curl -s -o /dev/null -w "site_status=%{http_code}\n" http://127.0.0.1/ || true
  fi

  echo "Deployment finished. Backend PID=$BACKEND_PID, log=$BACKEND_LOG"
}

stop_backend() {
  local pid

  if [ -f "$BACKEND_PID_FILE" ]; then
    pid=$(cat "$BACKEND_PID_FILE" || true)
    if [ -n "${pid:-}" ] && kill -0 "$pid" 2>/dev/null; then
      echo "Stopping backend PID $pid from $BACKEND_PID_FILE"
      kill "$pid" 2>/dev/null || true
      sleep 3
      if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null || true
      fi
    fi
    rm -f "$BACKEND_PID_FILE"
  fi

  if command -v fuser >/dev/null 2>&1; then
    fuser -k "${BACKEND_PORT}/tcp" >/dev/null 2>&1 || true
  fi

  if command -v lsof >/dev/null 2>&1; then
    lsof -ti tcp:"$BACKEND_PORT" | xargs -r kill >/dev/null 2>&1 || true
  fi

  if command -v pkill >/dev/null 2>&1; then
    pkill -f 'philosophy-backend-0.0.1-SNAPSHOT.jar|spring-boot:run' >/dev/null 2>&1 || true
  fi

  wait_for_port_release "$BACKEND_PORT" || {
    echo "Port $BACKEND_PORT is still occupied after stop attempts" >&2
    return 1
  }
}

echo "[1] pull latest"
cd "$ROOT_DIR"
git pull --ff-only origin main

prepare_frontend
prepare_database_user
build_backend
start_backend
verify_deployment

